<div class="dashboard-shell">
  <%- include('../partials/sidenav', { user }) %>
  <main class="dashboard-main" id="dashboardMain" data-app-slug="<%= typeof appSlug !== 'undefined' ? appSlug : '' %>">
    <header class="dashboard-topbar glass">
      <div>
        <h1>Developer Console</h1>
        <p>Build integrations, manage DeepLink, and monitor analytics.</p>
      </div>
      <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap;">
        <a href="/docs" class="btn btn-glass" target="_blank"><i class="fas fa-book"></i> Docs</a>
        <button class="btn btn-primary" id="createIntegrationBtn"><i class="fas fa-plus"></i> New Integration</button>
      </div>
    </header>

    <section id="routerLoader" class="router-loader hidden">
      <div class="loader-spinner"></div>
      <p>Loading…</p>
    </section>

    <section id="dashboardRouter" class="dashboard-router" data-base="/dev">
      <!-- Frontend-routed dev pages render here -->
    </section>
  </main>
</div>

<script>window.__USER__ = <%- JSON.stringify(user) %>;</script>
<script src="/js/numberFlow.js"></script>
<script src="/js/toast.js"></script>
<script src="/js/devDashboard.js"></script>
